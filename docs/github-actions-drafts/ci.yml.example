name: Public safety

on:
  push:
    branches: [main]
  pull_request:

permissions:
  contents: read

jobs:
  public-safety:
    name: public-safety
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Run public safety checks
        run: bash scripts/check-public-safety.sh
