# Purpose: Example GitHub Actions workflow for public safety checks.
# Read when: Enabling or reviewing CI workflow publication.
# Skip when: Current account cannot publish workflows or CI is not being changed.

name: Public safety

on:
  push:
    branches: [main]
  pull_request:

permissions:
  contents: read

jobs:
  public-safety:
    name: public-safety
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Run public safety checks
        run: bash scripts/check-public-safety.sh
